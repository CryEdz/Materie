{
	"version": "2.0.0",
	"tasks": [
		{
			"type": "func",
			"label": "func: host start",
			"command": "host start",
			"problemMatcher": "$func-python-watch",
			"isBackground": true,
			"dependsOn": "pip install (functions)",
			"options": {
				"cwd": "${workspaceFolder}/14_Cloud_Azure\\02_Esercizi"
			}
		},
		{
			"label": "pip install (functions)",
			"type": "shell",
			"osx": {
				"command": "${config:azureFunctions.pythonVenv}/bin/python -m pip install -r requirements.txt"
			},
			"windows": {
				"command": "${config:azureFunctions.pythonVenv}\\Scripts\\python -m pip install -r requirements.txt"
			},
			"linux": {
				"command": "${config:azureFunctions.pythonVenv}/bin/python -m pip install -r requirements.txt"
			},
			"problemMatcher": [],
			"options": {
				"cwd": "${workspaceFolder}/14_Cloud_Azure\\02_Esercizi"
			}
		}
		,
		{
			"label": "export nearest template for chat",
			"type": "shell",
			"command": "powershell -ExecutionPolicy Bypass -File \"${workspaceFolder}\\tools\\export-nearest-template.ps1\" \"${fileDirname}\"",
			"problemMatcher": [],
			"presentation": {
				"reveal": "silent"
			}
		}
	]
}