namespace Polimorfismo
{
    /// <summary>
    /// Classe che rappresenta un operaio specializzato.
    /// Estende la classe Operaio e aggiunge il concetto di missioni oceaniche.
    /// Lo stipendio include il bonus del tipo di operaio più le indennità
    /// relative alle missioni svolte sulle piattaforme oceaniche.
    /// </summary>
    internal class OperaioSpecializzato : Operaio
    {
        /// <summary>
        /// Lista delle missioni oceaniche completate dall'operaio
        /// </summary>
        public List<Missione> Missioni { get; set; }

        /// <summary>
        /// Costruttore della classe OperaioSpecializzato.
        /// </summary>
        /// <param name="cognome">Cognome del dipendente</param>
        /// <param name="nome">Nome del dipendente</param>
        /// <param name="pagaOraria">Paga oraria in euro</param>
        /// <param name="oreLavorate">Numero di ore lavorate</param>
        /// <param name="tipo">Tipo di operaio (Installatore o Manutentore)</param>
        public OperaioSpecializzato(string cognome, string nome, decimal pagaOraria, decimal oreLavorate, TipoOperaio tipo)
            : base(cognome, nome, pagaOraria, oreLavorate, tipo)
        {
            Missioni = new List<Missione>();
        }

        /// <summary>
        /// Aggiunge una missione oceanica all'operaio specializzato.
        /// </summary>
        /// <param name="missione">La missione da aggiungere</param>
        public void AggiungiMissione(Missione missione)
        {
            Missioni.Add(missione);
        }

        /// <summary>
        /// Calcola lo stipendio dell'operaio specializzato aggiungendo al bonus
        /// del tipo di operaio anche le indennità di tutte le missioni svolte.
        /// </summary>
        /// <returns>Lo stipendio lordo incluso bonus e indennità missioni</returns>
        public override decimal CalcolaStipendio()
        {
            decimal stipendio = base.CalcolaStipendio();
            foreach (var missione in Missioni)
            {
                stipendio += missione.Indennita;
            }
            return stipendio;
        }

        /// <summary>
        /// Visualizza le informazioni dell'operaio specializzato includendo
        /// le informazioni base, il tipo di operaio e l'elenco delle missioni svolte.
        /// </summary>
        public override void Visualizza()
        {
            base.Visualizza();
            Console.WriteLine($"Categoria: Operaio Specializzato");
            if (Missioni.Count > 0)
            {
                Console.WriteLine("Missioni:");
                foreach (var missione in Missioni)
                {
                    Console.WriteLine($"  - {missione.Nome}: {missione.Indennita:C}");
                }
            }
            Console.WriteLine();
        }
    }
}
